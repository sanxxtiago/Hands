--- !u!114 &2683451079960320945
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5270838611174572064}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e933f13d48c681d48b14750922ac906d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _comment: 'The XR Leap Provider Manager provides a single access point to the best
    possible source of tracking.


    This means you can distribute built applications
    for users that may be using either OpenXR or LeapC directly and the XR Leap Provider
    Manager will select the most suitable source.


    Please ensure the Service
    Providers that are child objects to this are set up correctly to allow for both
    to be suitable options. Child GameObjects will be automatically enabled when
    required, please do not enable them.'
  _isEditing: 0
